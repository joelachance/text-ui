{
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"]
    },
    "strict": true,
    "target": "esnext"
  },
  "include": ["registry/**/*.ts", "registry/**/*.tsx", "lib/**/*.ts"]
}
